# Required — bearer token for API authentication
UPREDIS_TOKEN=your-secret-token-here

# Redis connection (any Redis 6+ / Valkey / KeyDB)
# UPREDIS_REDIS_URL=redis://localhost:6379

# HTTP server
# UPREDIS_PORT=8080
# UPREDIS_HOST=0.0.0.0

# Logging
# UPREDIS_LOG_LEVEL=info          # debug, info, warn, error
# UPREDIS_LOG_FORMAT=json          # json, text

# Graceful shutdown
# UPREDIS_SHUTDOWN_TIMEOUT=30000   # Max ms to wait for request drain

# Per-request timeout (0 = disabled)
# UPREDIS_REQUEST_TIMEOUT=30000

# Maximum request body size in bytes (default: 10MB)
# UPREDIS_MAX_BODY_SIZE=10485760

# Maximum commands per pipeline / multi-exec request
# UPREDIS_MAX_PIPELINE_COMMANDS=1000

# Maximum concurrent SSE pubsub subscriptions (each holds a dedicated Redis connection)
# UPREDIS_MAX_SUBSCRIPTIONS=10000

# Prometheus metrics endpoint (GET /metrics)
# UPREDIS_METRICS=false
